<script nonce="13e8076237be2dd7fe55c771a7bba033">
    function toggleNav(buttonId, targetIds, crossId) {
        const btn = document.getElementById(buttonId);
        const cross = document.getElementById(crossId);
        if (btn && cross) {
            btn.onclick = function () {
                cross.classList.toggle("minus");
                const targets = Array.isArray(targetIds) ? targetIds : [targetIds];
                targets.forEach(id => {
                    const target = document.getElementById(id);
                    if (target) {
                        target.classList.toggle("blockStyle");
                    }
                });
                const isExpanded = targets.some(id => {
                    const el = document.getElementById(id);
                    return el && el.classList.contains("blockStyle");
                });
                btn.setAttribute('aria-expanded', isExpanded);
                };
            }
        }
        toggleNav("navLogo", "navigationLogo", "crossLogo");
        toggleNav("navIcon", "navigationIcon", "crossIcon");
        toggleNav("navBurger", ["navigationLogo", "navigationIcon"], "crossBurger");
</script>
