    window.gtag = gtag;

    gtag('js', new Date());
    gtag('config', 'G-J3G590WFED', {
      'page_title': window.error_type,
      'page_location': window.broken_url
    });
  }

  setTimeout(triggerGA, 2000);

  ['mousemove','touchstart','scroll','keydown'].forEach(function(ev) {
    window.addEventListener(ev, triggerGA, { once: true, passive: true });
